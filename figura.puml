' ================================================================
' ZONA 3 - DOMAIN LAYER
' ================================================================

package "domain" #E8F5E9 {

    package "domain.generic" #DCEDC8 {
        abstract class AggregateRoot <<aggregate>> {
            #id: T
            #status: StatusEnum
            #createdDate: LocalDateTime
            #updatedDate: LocalDateTime
            ─────────────────────────────
            +softDelete(): void
            +getId(): T
            +getStatus(): StatusEnum
        }
        abstract class GenericDomain <<entity>> {
            <<Base Value Object>>
        }
        class EntityException <<exception>>
    }

    package "domain.card" #C8E6C9 {

        class Card <<aggregate>> {
            <<extends AggregateRoot<CardId>>>
            ─────────────────────────────
            -typeCard: TypeCardEnum
            -categoryCard: CategoryCardEnum
            -credit: Credit
            -cardStatus: CardStatusEnum
            -cardAccountId: CardAccountId
            -paymentDay: PaymentDay
            ─────────────────────────────
            +updateStatus(isOvercharged: Boolean): void
            +validateIfCardIfInDebt(): void
            +getRatio(): BigDecimal
            +close(): void
        }

        package "card.value objects" #F0F4C3 {
            class CardId <<valueObject>> {
                -value: Long
                +{static} create(value: Long): CardId
                +getValue(): Long
            }
            class CardAccountId <<valueObject>> {
                -value: Long
                +{static} create(value: Long): CardAccountId
            }
            class Credit <<valueObject>> {
                -amount: Amount
                -debtTax: BigDecimal
                +{static} create(amount: Amount, debtTax: BigDecimal): Credit
            }
            class PaymentDay <<valueObject>> {
                -value: Short
                +{static} create(value: Short): PaymentDay
            }
        }

        class CardException <<exception>>
    }

    package "domain.balance" #C8E6C9 {

        interface Balance <<entity>> {
            +getCardId(): CardId
            +getTotal(): Amount
            +getAvailable(): Amount
            +getOld(): Amount
            +getDateRange(): DateRange
            +getStatus(): StatusEnum
            +getId(): BalanceId
            +close(): void
        }

        class BalanceOperable <<entity>> {
            <<implements Balance>>
            -cardId: CardId
            -total: Amount
            -available: Amount
            -old: Amount
            -dateRange: DateRange
            ─────────────────────────────
            +isOvercharged(): boolean
        }

        class BalanceConsumo <<entity>> {
            <<extends BalanceOperable>>
            ─────────────────────────────
            +{static} from(balance: Balance): BalanceConsumo
            +apply(consumptionAmount: Amount): void
        }

        class BalancePago <<entity>> {
            <<extends BalanceOperable>>
            ─────────────────────────────
            +{static} from(balance: Balance): BalancePago
            +apply(paymentAmount: Amount): void
            +validateIfPaymentIsPossible(...): void
        }

        class BalanceSnapshot <<entity>> {
            <<Immutable snapshot>>
        }

        package "balance.factory" #F0F4C3 {
            interface BalanceFactory <<factory>> {
                +create(CreateBalanceRequestFirstDto): Balance
            }
            class BalanceFactoryImpl <<factory>> {
                +create(CreateBalanceRequestFirstDto): Balance
            }
        }

        class BalanceId <<valueObject>> {
            -value: Long
        }
    }

    package "domain.consumption" #C8E6C9 {
        class Consumption <<aggregate>> {
            -consumptionId: ConsumptionId
            -cardId: Long
            -consumptionAmount: Amount
            -sellerName: String
            ─────────────────────────────
            +{static} builder(): ConsumptionBuilder
        }
        class ConsumptionId <<valueObject>> {
            -value: UUID
        }
    }

    package "domain.payment" #C8E6C9 {
        interface Payment <<entity>> {
            +validateIfPaymentIsPossible(...): void
            +getPaymentId(): PaymentId
            +getCardId(): Long
            +getPaymentAmount(): Amount
        }
        class NormalPayment <<entity>> {
            <<implements Payment>>
        }
        class MinimunPayment <<entity>> {
            <<implements Payment>>
        }
        class Prepayment <<entity>> {
            <<implements Payment>>
        }
        class TotalPayment <<entity>> {
            <<implements Payment>>
        }

        package "payment.factory" #F0F4C3 {
            interface PaymentFactory <<factory>> {
                +create(CreatePaymentRequestFirstDto): Payment
            }
            class PaymentFactoryImpl <<factory>> {
                +create(CreatePaymentRequestFirstDto): Payment
            }
        }

        class PaymentId <<valueObject>> {
            -value: UUID
        }
    }

    package "domain.benefit" #C8E6C9 {
        class Benefit <<aggregate>> {
            <<extends AggregateRoot<BenefitId>>>
            ─────────────────────────────
            -cardId: Long
            -hasDiscount: Boolean
            -totalPoints: Point
            -multiplierPoints: BigDecimal
            ─────────────────────────────
            +accumulate(amount: Amount, ratio: BigDecimal): void
            +discount(amount: Amount, point: Point): Amount
            +discountPolicy(hasDiscount: Boolean, multiplierPoints: BigDecimal)
            +close(): void
        }
    }

    package "domain.base" #C8E6C9 {
        package "base.value objects" #F0F4C3 {
            class Amount <<valueObject>> {
                -currency: Currency
                -amount: BigDecimal
                +{static} create(currency: Currency, amount: BigDecimal): Amount
                +convertTo(targetCurrency: CurrencyEnum): BigDecimal
            }
            class Currency <<valueObject>> {
                -currency: CurrencyEnum
                -exchangeRate: BigDecimal
                +{static} create(currency: CurrencyEnum, exchangeRate: BigDecimal): Currency
            }
