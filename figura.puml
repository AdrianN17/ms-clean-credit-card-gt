@startuml figura
' ================================================================
' C4 Level 4 - Code Diagram
' Proyecto : ms-clean-credit-card-gt
' Arquitectura: Clean Architecture + Hexagonal (Ports & Adapters)
' Perfiles Spring Boot:
'   "old" → Inbound SOAP  + Outbound MongoDB
'   "new" → Inbound REST  + Outbound Cosmos DB
' ================================================================

skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 60
skinparam classFontSize 10
skinparam classAttributeFontSize 9
skinparam packageFontSize 11
skinparam packageFontStyle bold

skinparam class {
    BackgroundColor White
    BorderColor #555555
    ArrowColor #333333
}
skinparam package {
    BorderColor #888888
    BackgroundColor #FAFAFA
}

' ─── Estereotipos por color ───────────────────────────────────────
skinparam class {
    BackgroundColor<<aggregate>>    #C8E6C9
    BackgroundColor<<entity>>       #BBDEFB
    BackgroundColor<<valueObject>>  #FFF9C4
    BackgroundColor<<domainSvc>>    #DCEDC8
    BackgroundColor<<factory>>      #F0F4C3
    BackgroundColor<<useCase>>      #FCE4EC
    BackgroundColor<<appService>>   #F8BBD0
    BackgroundColor<<bizService>>   #F3E5F5
    BackgroundColor<<portIn>>       #E8EAF6
    BackgroundColor<<portOut>>      #E0F7FA
    BackgroundColor<<adapter>>      #FFF3E0
    BackgroundColor<<controller>>   #EDE7F6
    BackgroundColor<<delegate>>     #D1C4E9
    BackgroundColor<<jpaRepo>>      #E8EAF6
    BackgroundColor<<nosqlRepo>>    #B3E5FC
    BackgroundColor<<externalRepo>> #FFE0B2
    BackgroundColor<<mapper>>       #F5F5F5
    BackgroundColor<<config>>       #ECEFF1
    BackgroundColor<<aspect>>       #FFCCBC
    BackgroundColor<<exception>>    #FFCDD2
    BackgroundColor<<command>>      #FFF8E1
    BackgroundColor<<query>>        #E1F5FE
}

' ================================================================
' ZONA 1 - INFRASTRUCTURE: INBOUND ADAPTERS (Presenter)
' ================================================================

package "infrastructure.presenter" #FAFAFA {

    package "soap  [Profile: old]" #EDE7F6 {

        class CreditCardControllerSOAPImpl <<controller>> {
            <<@WebService serviceName="CreditCardService">>
            <<@Component @Profile("old")>>
            ─────────────────────────────
            -creditCardDelegateSOAP: CreditCardDelegateSOAP
            ─────────────────────────────
            +retrieveBalance(RetrieveBalanceRequest): RetrieveBalanceResponse
            +initiateCard(InitiateCardRequest): InitiateCardResponse
            +controlCard(ControlCardRequest): ControlCardResponse
            +initiatePayment(InitiatePaymentRequest): InitiatePaymentResponse
            +controlPayment(ControlPaymentRequest): ControlPaymentResponse
            +initiateConsumption(InitiateConsumptionRequest): InitiateConsumptionResponse
            +exchangeConsumption(ExchangeConsumptionRequest): ExchangeConsumptionResponse
            +controlConsumption(ControlConsumptionRequest): ControlConsumptionResponse
            +retrieveConsumption(RetrieveConsumptionRequest): RetrieveConsumptionResponse
            +retrievePayment(RetrievePaymentRequest): RetrievePaymentResponse
        }

        interface CreditCardControllerSOAP <<portIn>> {
            <<@WebService targetNamespace="http://bank.com/credit_card">>
            +retrieveBalance(RetrieveBalanceRequest)
            +initiateCard(InitiateCardRequest)
            +controlCard(ControlCardRequest)
            +initiatePayment(InitiatePaymentRequest)
            +controlPayment(ControlPaymentRequest)
            +initiateConsumption(InitiateConsumptionRequest)
            +exchangeConsumption(ExchangeConsumptionRequest)
            +controlConsumption(ControlConsumptionRequest)
            +retrieveConsumption(RetrieveConsumptionRequest)
            +retrievePayment(RetrievePaymentRequest)
        }

        class CreditCardDelegateSOAPImpl <<delegate>> {
            -cardCreateService: CardCreateService
            -cardCloseService: CardCloseService
            -cardFindByIdService: CardFindByIdService
            -paymentProcessService: PaymentProcessService
            -paymentCancelService: PaymentCancelService
            -paymentFindByDatesAndCardIdService: PaymentFindByDatesAndCardIdService
            -consumptionProcessService: ConsumptionProcessService
            -consumptionCancelService: ConsumptionCancelService
            -consumptionSplitService: ConsumptionSplitService
            -consumptionFindByDatesAndCardIdService: ConsumptionFindByDatesAndCardIdService
            -cardApiMapperRequestCommand: CardApiMapperRequestCommand
            -consumptionApiMapperRequestCommand: ConsumptionApiMapperRequestCommand
            -paymentApiMapperRequestCommand: PaymentApiMapperRequestCommand
        }

        interface CreditCardDelegateSOAP <<portIn>> {
            +retrieveBalance(RetrieveBalanceRequest): RetrieveBalanceResponse
            +initiateCard(InitiateCardRequest): InitiateCardResponse
            +controlCard(ControlCardRequest): ControlCardResponse
            +initiatePayment(InitiatePaymentRequest): InitiatePaymentResponse
            +controlPayment(ControlPaymentRequest): ControlPaymentResponse
            +initiateConsumption(InitiateConsumptionRequest): InitiateConsumptionResponse
            +exchangeConsumption(ExchangeConsumptionRequest): ExchangeConsumptionResponse
            +controlConsumption(ControlConsumptionRequest): ControlConsumptionResponse
            +retrieveConsumption(RetrieveConsumptionRequest): RetrieveConsumptionResponse
            +retrievePayment(RetrievePaymentRequest): RetrievePaymentResponse
        }

        package "soap.mapper" #FAFAFA {
            interface CardApiMapperRequestCommand_SOAP <<mapper>> {
                <<soap>>
                +toCommand(InitiateCardRequest): CardCreateCommand
                +toCommandId(ControlCardRequest): CardCloseCommand
                +toResponse(LoadCardBalanceBenefitView): CardResponse
            }
            class CardApiMapperRequestCommandImpl_SOAP <<mapper>> {
                <<soap>>
            }
            interface ConsumptionApiMapperRequestCommand_SOAP <<mapper>> {
                <<soap>>
                +toCommand(InitiateConsumptionRequest): CardProcessConsumptionCommand
                +toCommandId(ControlConsumptionRequest): ConsumptionCancelCommand
                +toCommandIdR(ExchangeConsumptionRequest): ConsumptionSplitCommand
                +toResponse(LoadConsumptionView): ConsumptionResponseList
            }
            class ConsumptionApiMapperRequestCommandImpl_SOAP <<mapper>> {
                <<soap>>
            }
            interface PaymentApiMapperRequestCommand_SOAP <<mapper>> {
                <<soap>>
                +toCommand(InitiatePaymentRequest): CardProcessPaymentCommand
                +toCommandId(ControlPaymentRequest): PaymentCancelCommand
                +toResponse(LoadPaymentView): PaymentResponseList
            }
            class PaymentApiMapperRequestCommandImpl_SOAP <<mapper>> {
                <<soap>>
            }
        }

        package "soap.schema.request" #FAFAFA {
            class InitiateCardRequest_SOAP <<command>>
            class ControlCardRequest_SOAP  <<command>>
            class RetrieveBalanceRequest_SOAP <<query>>
            class InitiatePaymentRequest_SOAP <<command>>
            class ControlPaymentRequest_SOAP <<command>>
            class InitiateConsumptionRequest_SOAP <<command>>
            class ExchangeConsumptionRequest_SOAP <<command>>
            class ControlConsumptionRequest_SOAP <<command>>
            class RetrieveConsumptionRequest_SOAP <<query>>
            class RetrievePaymentRequest_SOAP <<query>>
        }

        package "soap.schema.response" #FAFAFA {
            class RetrieveBalanceResponse_SOAP <<entity>> {
                -data: CardResponse
                -tracking: Tracking
            }
            class InitiateCardResponse_SOAP <<entity>> {
                -data: LongResponse
                -tracking: Tracking
            }
            class InitiatePaymentResponse_SOAP <<entity>>
            class InitiateConsumptionResponse_SOAP <<entity>>
            class ExchangeConsumptionResponse_SOAP <<entity>>
            class ControlCardResponse_SOAP <<entity>>
            class ControlPaymentResponse_SOAP <<entity>>
            class ControlConsumptionResponse_SOAP <<entity>>
            class RetrieveConsumptionResponse_SOAP <<entity>>
            class RetrievePaymentResponse_SOAP <<entity>>
        }
    }

    package "rest  [Profile: new]" #F3E5F5 {

        class CardManagementApiImpl <<controller>> {
            <<@RestController @Profile("new")>>
            ─────────────────────────────
            -cardManagementDelegate: CardManagementDelegate
            ─────────────────────────────
            +retrieveBalance(cardId: Long): ResponseEntity
            +initiateCard(InitiateCardRequest, BindingResult): ResponseEntity
            +controlCard(cardId: Long): ResponseEntity
            +initiatePayment(cardId: Long, InitiatePaymentRequest): ResponseEntity
            +controlPayment(cardId: Long, paymentId: UUID): ResponseEntity
            +initiateConsumption(cardId: Long, InitiateConsumptionRequest): ResponseEntity
            +exchangeConsumption(cardId: Long, consumptionId: UUID, ...): ResponseEntity
            +controlConsumption(cardId: Long, consumptionId: UUID): ResponseEntity
            +retrieveConsumption(cardId: Long, dateStart: LocalDate, dateEnd: LocalDate): ResponseEntity
            +retrievePayment(cardId: Long, dateStart: LocalDate, dateEnd: LocalDate): ResponseEntity
        }

        interface CardManagementApi <<portIn>> {
            <<OpenAPI Generated Interface>>
        }

        class CardManagementDelegateImpl <<delegate>> {
            -cardCreateService: CardCreateService
            -cardCloseService: CardCloseService
            -cardFindByIdService: CardFindByIdService
            -paymentProcessService: PaymentProcessService
            -paymentCancelService: PaymentCancelService
            -paymentFindByDatesAndCardIdService: PaymentFindByDatesAndCardIdService
            -consumptionProcessService: ConsumptionProcessService
            -consumptionCancelService: ConsumptionCancelService
            -consumptionSplitService: ConsumptionSplitService
            -consumptionFindByDatesAndCardIdService: ConsumptionFindByDatesAndCardIdService
            -cardApiMapperRequestCommand: CardApiMapperRequestCommand
            -consumptionApiMapperRequestCommand: ConsumptionApiMapperRequestCommand
            -paymentApiMapperRequestCommand: PaymentApiMapperRequestCommand
        }

        interface CardManagementDelegate <<portIn>> {
            +retrieveBalance(cardId: Long): ResponseEntity<RetrieveBalance200Response>
            +initiateCard(InitiateCardRequest, BindingResult): ResponseEntity<Long202Response>
            +controlCard(cardId: Long): ResponseEntity<Long202Response>
            +initiatePayment(cardId: Long, InitiatePaymentRequest, BindingResult): ResponseEntity<UUID202Response>
            +controlPayment(cardId: Long, paymentId: UUID, BindingResult): ResponseEntity<UUID202Response>
            +initiateConsumption(cardId: Long, InitiateConsumptionRequest, BindingResult): ResponseEntity<UUID202Response>
            +exchangeConsumption(cardId: Long, consumptionId: UUID, ExchangeConsumptionRequest, BindingResult): ResponseEntity<UUIDList202Response>
            +controlConsumption(cardId: Long, consumptionId: UUID): ResponseEntity<UUID202Response>
            +retrieveConsumption(cardId: Long, dateStart: LocalDate, dateEnd: LocalDate): ResponseEntity<RetrieveConsumption200Response>
            +retrievePayment(cardId: Long, dateStart: LocalDate, dateEnd: LocalDate): ResponseEntity<RetrievePayment200Response>
        }

        package "rest.mapper" #FAFAFA {
            interface CardApiMapperRequestCommand_REST <<mapper>> {
                <<rest>>
                +toCommand(card data): CardCreateCommand
                +toCommandId(cardId: Long): CardCloseCommand
                +toResponse(view): RetrieveBalance200Response_data
            }
            class CardApiMapperRequestCommandImpl_REST <<mapper>>
            interface ConsumptionApiMapperRequestCommand_REST <<mapper>> {
                <<rest>>
            }
            class ConsumptionApiMapperRequestCommandImpl_REST <<mapper>>
            interface PaymentApiMapperRequestCommand_REST <<mapper>> {
                <<rest>>
            }
            class PaymentApiMapperRequestCommandImpl_REST <<mapper>>
        }

        package "rest.schema" #FAFAFA {
            class InitiateCardRequest_REST <<command>>
            class InitiatePaymentRequest_REST <<command>>
            class InitiateConsumptionRequest_REST <<command>>
            class ExchangeConsumptionRequest_REST <<command>>
            class Long202Response <<entity>>
            class UUID202Response <<entity>>
            class UUIDList202Response <<entity>>
            class RetrieveBalance200Response <<entity>>
            class RetrieveConsumption200Response <<entity>>
            class RetrievePayment200Response <<entity>>
        }
    }
}

